<?xml version="1.0"?>

<launch>

  <param name="/use_sim_time" value="true"/>

  <node
      name="gazebo"
      pkg="gazebo_ros"
      type="gazebo"
      args="/home/nci/sim_ws/src/Models/warehouse_world/warehouse_world.sdf"
      
      output="screen"/>

  <param
      name="robot_description"
      command="$(find xacro)/xacro --inorder $(find turtlebot3_description)/urdf/turtlebot3_burger.urdf.xacro"/>

  <node
      pkg="robot_state_publisher"
      type="robot_state_publisher"
      name="robot_state_publisher"/>

  <node
      pkg="gazebo_ros"
      type="spawn_model"
      name="spawn_turtlebot"
      args="-urdf -model turtlebot3 -x 0 -y 0 -z 0.2 -param robot_description"/>

</launch>
